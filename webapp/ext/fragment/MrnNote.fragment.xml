<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:macros="sap.fe.macros">
	<VBox id="_IDGenVBox1" width="100%" class="sapUiResponsiveMargin">
		<!-- Company Header Section -->
		<VBox id="_IDGenVBox2" alignItems="Center" class="sapUiNoMargin">
			<Title id="_IDGenTitle" text="Shivani Detergents Pvt. Ltd" level="H3" textAlign="Center" class="sapUiNoMarginBottom sapUiSmallMarginTop"/>
			<Title id="_IDGenTitle1" text="Address 1" level="H5" textAlign="Center" class="sapUiNoMarginBottom sapUiNoMarginTop"/>
		</VBox>

		<!-- Material Note Title -->
		<VBox id="_IDGenVBox3" alignItems="Center" class="sapUiNoMargin">
			<Title id="_IDGenTitle2" level="H4" text="Material Note {Document}" textAlign="Center" class="sapUiNoMarginBottom sapUiSmallMarginTop"/>
		</VBox>

		<!-- Horizontal Divider -->
		<core:HTML id="_IDGenHTML" content="&lt;hr style='border: 1px solid #000; margin: 8px 0;'/&gt;"/>

		<!-- Data Table with Border -->
		<HBox id="_IDGenDataTable" width="100%" class="sapUiNoMargin">
			<!-- Left Section - Business Partner and Direction -->
			<VBox id="_IDGenVBoxLeft" class="sapUiNoMargin" width="50%">
				<!-- Business Partner Row -->
				<HBox id="_IDGenHBoxBP" class="sapUiNoMargin">
					<VBox id="_IDGenVBoxBPLabel" width="40%">
						<Text id="_IDGenTextBPLabel" text="Business Partner" class="sapUiNoMarginBottom"/>
					</VBox>
					<VBox id="_IDGenVBoxBPColon" width="5%">
						<Text id="_IDGenTextBPColon" text=":" class="sapUiNoMarginBottom"/>
					</VBox>
					<VBox id="_IDGenVBoxBPValue" width="55%">
						<Text id="_IDGenBPAttr" text="{bpName}({Partner})" class="sapUiNoMarginBottom"/>
					</VBox>
				</HBox>

				<!-- Direction Row -->
				<HBox id="_IDGenHBoxDir" class="sapUiNoMargin">
					<VBox id="_IDGenVBoxDirLabel" width="40%">
						<Text id="_IDGenTextDirLabel" text="Direction" class="sapUiNoMarginBottom"/>
					</VBox>
					<VBox id="_IDGenVBoxDirColon" width="5%">
						<Text id="_IDGenTextDirColon" text=":" class="sapUiNoMarginBottom"/>
					</VBox>
					<VBox id="_IDGenVBoxDirValue" width="55%">
						<Text id="_IDGenDirAttr" text="{DirDesc}({Direction})" class="sapUiNoMarginBottom"/>
					</VBox>
				</HBox>

				<!-- Date Row -->
				<HBox id="_IDGenHBoxDate" class="sapUiNoMargin">
					<VBox id="_IDGenVBoxDateLabel" width="40%">
						<Text id="_IDGenTextDateLabel" text="Date" class="sapUiNoMarginBottom"/>
					</VBox>
					<VBox id="_IDGenVBoxDateColon" width="5%">
						<Text id="_IDGenTextDateColon" text=":" class="sapUiNoMarginBottom"/>
					</VBox>
					<VBox id="_IDGenVBoxDateValue" width="55%">
						<Text id="_IDGenTextDate" text="{path: 'MrnDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd-MMM-yyyy'}}" class="sapUiNoMarginBottom"/>
					</VBox>
				</HBox>
			</VBox>

			<!-- Right Section - Transporter, Vehicle, Driver -->
			<VBox id="_IDGenVBoxRight" class="sapUiNoMargin" width="50%">
				<!-- Transporter Row -->
				<HBox id="_IDGenHBoxTransp" class="sapUiNoMargin">
					<VBox id="_IDGenVBoxTranspLabel" width="40%">
						<Text id="_IDGenTextTranspLabel" text="Transporter" class="sapUiNoMarginBottom"/>
					</VBox>
					<VBox id="_IDGenVBoxTranspColon" width="5%">
						<Text id="_IDGenTextTranspColon" text=":" class="sapUiNoMarginBottom"/>
					</VBox>
					<VBox id="_IDGenVBoxTranspValue" width="55%">
						<Text id="_IDGenTranspAttr" text="{TransporterName}({Transporter})" class="sapUiNoMarginBottom"/>
					</VBox>
				</HBox>

				<!-- Vehicle Number Row -->
				<HBox id="_IDGenHBoxVehicle" class="sapUiNoMargin">
					<VBox id="_IDGenVBoxVehicleLabel" width="40%">
						<Text id="_IDGenTextVehicleLabel" text="Vehicle Number" class="sapUiNoMarginBottom"/>
					</VBox>
					<VBox id="_IDGenVBoxVehicleColon" width="5%">
						<Text id="_IDGenTextVehicleColon" text=":" class="sapUiNoMarginBottom"/>
					</VBox>
					<VBox id="_IDGenVBoxVehicleValue" width="55%">
						<Text id="_IDGenTextVehicleNo" text="{VehicleNo}" class="sapUiNoMarginBottom"/>
					</VBox>
				</HBox>

				<!-- Driver Name Row -->
				<HBox id="_IDGenHBoxDriver" class="sapUiNoMargin">
					<VBox id="_IDGenVBoxDriverLabel" width="40%">
						<Text id="_IDGenTextDriverLabel" text="Driver Name" class="sapUiNoMarginBottom"/>
					</VBox>
					<VBox id="_IDGenVBoxDriverColon" width="5%">
						<Text id="_IDGenTextDriverColon" text=":" class="sapUiNoMarginBottom"/>
					</VBox>
					<VBox id="_IDGenVBoxDriverValue" width="55%">
						<Text id="_IDGenTextDriver" text="{Name}" class="sapUiNoMarginBottom"/>
					</VBox>
				</HBox>
			</VBox>
		</HBox>

		<!-- Horizontal Divider -->
		<core:HTML id="_IDGenHTML1" content="&lt;hr style='border: 1px solid #000; margin: 8px 0;'/&gt;"/>

		<!-- Items Section -->
		<VBox id="_IDGenItemsSection" width="100%" class="sapUiNoMargin">
			<Title id="_IDGenItemsTitle" text="Item Details" level="H5" class="sapUiSmallMarginTop sapUiSmallMarginBottom"/>
			
			<!-- Items Table -->
			<Table id="_IDGenItemsTable" width="100%" class="sapUiNoMargin sapUiResponsiveMargin">
				<columns>
					<Column id="_IDGenColItem">
						<Text id="_IDGenText1" text="Item"/>
					</Column>
					<Column id="_IDGenColRefDoc">
						<Text id="_IDGenText2" text="Ref Doc"/>
					</Column>
					<Column id="_IDGenColRefItem">
						<Text id="_IDGenText3" text="Ref Item"/>
					</Column>
					<Column id="_IDGenColProduct">
						<Text id="_IDGenText4" text="Product"/>
					</Column>
					<Column id="_IDGenColProductDesc">
						<Text id="_IDGenText5" text="Product Desc"/>
					</Column>
					<Column id="_IDGenColQuantity">
						<Text id="_IDGenText6" text="Quantity"/>
					</Column>
					<Column id="_IDGenColPackProduct">
						<Text id="_IDGenText7" text="Pkg Product"/>
					</Column>
					<Column id="_IDGenColPackQty">
						<Text id="_IDGenText8" text="Pkg Qty"/>
					</Column>
					<Column id="_IDGenColPackWeight">
						<Text id="_IDGenText9" text="Pkg Weight"/>
					</Column>
				</columns>
				<ColumnListItem id="_IDGenItemRow1">
					<Text id="_IDGenText10" text="1"/>
					<Text id="_IDGenText11" text="1100000005"/>
					<Text id="_IDGenText12" text="10"/>
					<Text id="_IDGenText13" text="110000002"/>
					<Text id="_IDGenText14" text="Salt Granuals"/>
					<Text id="_IDGenText15" text="0.000"/>
					<Text id="_IDGenText16" text="130000010"/>
					<Text id="_IDGenText17" text="2"/>
					<Text id="_IDGenText18" text="8.000"/>
				</ColumnListItem>
				<ColumnListItem id="_IDGenItemRow2">
					<Text id="_IDGenText19" text="2"/>
					<Text id="_IDGenText20" text="1100000006"/>
					<Text id="_IDGenText21" text="20"/>
					<Text id="_IDGenText22" text="110000003"/>
					<Text id="_IDGenText23" text="Sugar Crystals"/>
					<Text id="_IDGenText24" text="5.000"/>
					<Text id="_IDGenText25" text="130000011"/>
					<Text id="_IDGenText26" text="3"/>
					<Text id="_IDGenText27" text="10.000"/>
				</ColumnListItem>
			</Table>
		</VBox>
	</VBox>
	<VBox id="_IDGenVBox"  width="100%" class="sapUiNoMargin">
		<HBox id="_IDGenHBox" height="20px">
			<Label id="_IDGenLabel1" text="Security Signature"></Label>
		</HBox>
		<HBox id="_IDGenHBox1"  height="20px">
			<Label id="_IDGenLabel2" text="Quality Signature"></Label>
		</HBox>
		<HBox id="_IDGenHBox2" height="20px">
			<Label id="_IDGenLabel3" text="Warehouse Signature"></Label>
		</HBox>
	</VBox>
</core:FragmentDefinition>
